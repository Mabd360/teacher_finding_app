# =============================================================================
# Environment Variables for Teacher Finder Backend
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=teacher_finder

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- Server ---
PORT=5000
